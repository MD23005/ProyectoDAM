<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA"
    tools:context=".DetallesClienteActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarDetalleCliente"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="Perfil del Cliente"
        app:titleTextColor="@android:color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvDetalleNombreCliente"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="20dp"
                android:gravity="center"
                android:textColor="#212121"
                android:textSize="24sp"
                android:textStyle="bold"
                tools:text="Juan Pérez"
                app:layout_constraintTop_toBottomOf="@+id/toolbarDetalleCliente"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:ignore="NotSibling" />

            <View
                android:id="@+id/divisorCliente"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="30dp"
                android:layout_marginTop="20dp"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@id/tvDetalleNombreCliente" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/divisorCliente"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Datos de Identificación y Contacto"
                        android:textColor="#757575"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="ID Cliente:"
                            android:textColor="#616161"
                            android:textSize="16sp" />
                        <TextView
                            android:id="@+id/tvDetalleIDCliente"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#212121"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="102" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="DUI:"
                            android:textColor="#616161"
                            android:textSize="16sp" />
                        <TextView
                            android:id="@+id/tvDetalleDui"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#212121"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="00000000-0" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Teléfono:"
                            android:textColor="#616161"
                            android:textSize="16sp" />
                        <TextView
                            android:id="@+id/tvDetalleTelefono"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#212121"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="7777-7777" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Correo Electrónico:"
                            android:textColor="#616161"
                            android:textSize="16sp" />
                        <TextView
                            android:id="@+id/tvDetalleCorreo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#212121"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="cliente@correo.com" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</LinearLayout>