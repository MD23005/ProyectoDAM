<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#1A2332">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Foto del vehículo -->
        <ImageView
            android:id="@+id/tvFoto"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background"
            android:contentDescription="Foto del vehículo" />

        <!-- Datos del vehículo -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp">

            <!-- Marca y Modelo -->
            <TextView
                android:id="@+id/tvMarca"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Marca"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/tvModelo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Modelo"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@android:color/white" />

            <!-- Año -->
            <TextView
                android:id="@+id/tvAño"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Año"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                android:textColor="@color/yellow"/>

            <!-- Placa -->
            <TextView
                android:id="@+id/tvPlaca"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Placa: ABC-123"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                android:textColor="@color/yellow"/>

            <!-- Tipo de vehículo -->
            <TextView
                android:id="@+id/tvTipo_Vehiculo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo: Sedán"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                android:textColor="@color/yellow"/>

            <!-- Precio -->
            <TextView
                android:id="@+id/tvPrecio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0.00"
                android:textSize="14sp"
                android:textColor="#2196F3"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

            <!-- Estado -->
            <TextView
                android:id="@+id/tvEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Disponible"
                android:textSize="12sp"
                android:textColor="#4CAF50"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Botones de acción -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnEditar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Editar" />

            <ImageButton
                android:id="@+id/btnEliminar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Eliminar"
                android:layout_marginTop="8dp" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>